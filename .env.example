# Subsonic-compatible music backend
SUBSONIC_URL=https://music.example.com
SUBSONIC_USERNAME=your_username
SUBSONIC_PASSWORD=your_password

# Mumble server
MUMBLE_HOST=mumble.example.com
MUMBLE_PORT=64738

# Melody coordinator (sits in root, receives whispers)
MUMBLE_USERNAME=Melody
MUMBLE_PASSWORD=

MUMBLE_TLS=false

# MelodyPlayer pool (one connection per active channel)
# pool = fixed slots MelodyPlayer-1 .. MelodyPlayer-N
# per_channel = MelodyPlayer-{channel_name} per channel (good when no password required)
PLAYER_MODE=pool
PLAYER_POOL_SIZE=5
PLAYER_USERNAME_PREFIX=MelodyPlayer
PLAYER_PASSWORD=

# Accept commands typed in root channel (in addition to whispers to Melody)
COORDINATOR_ACCEPT_ROOT_MESSAGES=true

# Command prefixes (comma-separated, longest match wins)
COMMAND_PREFIXES=m/,melody/,/

# Channel behavior (seconds before player leaves an empty channel)
DISCONNECT_GRACE_PERIOD=300

# Audio buffering (important for slow backends like Octo Fiesta)
AUDIO_BUFFER_MAX_MB=256
AUDIO_BUFFER_START_SECONDS=3

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
